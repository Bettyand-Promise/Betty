# ---- Supabase ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=firstchoice

# ---- Admin auth ----
# Secret used to sign the admin session JWT. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# ---- Server ----
# Set to "production" when self-hosting (enables fail-fast env checks + JSON logs).
# Vercel sets this automatically.
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins (the users + admin apps)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
