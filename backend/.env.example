# ---- Database (Neon Postgres) ----
# Use the POOLED connection string from the Neon dashboard (has "-pooler" in the
# host). It already includes ?sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# ---- Admin auth (single admin, server-side) ----
ADMIN_EMAIL=admin@bettyandpromise.com
# Generate the hash with:  npm run db:hash -- "your-password"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=firstchoice

# ---- Admin session ----
# Secret used to sign the admin session JWT. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# ---- Server ----
# Set to "production" when self-hosting (enables fail-fast env checks + JSON logs).
# Vercel sets this automatically.
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins (the users + admin apps)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- One-time data import only (from the old Supabase project) ----
# Needed by `npm run db:import` to copy existing content into Neon. Safe to
# delete after the import succeeds — the app never uses these.
# SUPABASE_URL=https://YOUR-OLD-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-old-service-role-key
